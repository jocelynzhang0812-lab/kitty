KITTY_ENV=production
KITTY_BOT_NAME=Team Assistant
KITTY_MODEL_PROVIDER=openai_compatible
KITTY_PROJECT_ROOT=/app/kitty-runtime
KITTY_STATE_DIR=/data/kitty
KITTY_WORKSPACE_ROOT=/data/kitty/workspaces
KITTY_SYSTEM_PROMPT=You are a helpful Feishu assistant. Answer clearly and concisely.

LLM_API_KEY=replace-me
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=replace-with-your-model
LLM_TIMEOUT_SECONDS=120

KITTY_WORKER_CONCURRENCY=4
KITTY_JOB_LEASE_SECONDS=180
KITTY_POLL_INTERVAL_SECONDS=0.25
KITTY_DELIVERY_MAX_ATTEMPTS=5
KITTY_DELIVERY_RETRY_BASE_SECONDS=1

KITTY_TOOL_EXECUTOR=subprocess
KITTY_TOOL_DENYLIST=
KITTY_TOOL_MAX_OUTPUT_BYTES=65536
# For stricter isolation, set KITTY_TOOL_EXECUTOR=container and provide:
# KITTY_TOOL_CONTAINER_IMAGE=kitty-runtime:latest
# KITTY_TOOL_CONTAINER_WORKSPACE=/app/kitty-runtime
# KITTY_TOOL_CONTAINER_NETWORK=none
# KITTY_TOOL_CONTAINER_MEMORY=256m
# KITTY_TOOL_CONTAINER_CPUS=1
# KITTY_TOOL_CONTAINER_PIDS_LIMIT=128
# KITTY_TOOL_CONTAINER_TMPFS_SIZE=64m
# KITTY_TOOL_CONTAINER_READONLY_MOUNTS=
KITTY_TOOL_MODULES=examples.tools
KITTY_HOOK_PATHS=
