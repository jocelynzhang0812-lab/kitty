# Runtime
KITTY_ENV=production
KITTY_MODEL_PROVIDER=openai_compatible
KITTY_STATE_DIR=/data/kitty
KITTY_PROJECT_ROOT=/app/kitty-runtime
KITTY_SYSTEM_PROMPT=You are a helpful Feishu assistant. Answer clearly and concisely.

# Any OpenAI-compatible Chat Completions API
LLM_API_KEY=replace-me
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=replace-with-your-model
LLM_TIMEOUT_SECONDS=120

# Feishu custom app
FEISHU_APP_ID=cli_replace_me
FEISHU_APP_SECRET=replace-me
FEISHU_VERIFICATION_TOKEN=replace-me
FEISHU_ENCRYPT_KEY=replace-me
FEISHU_REQUIRE_MENTION=1
FEISHU_MAX_CLOCK_SKEW_SECONDS=300

# Durable delivery
KITTY_DELIVERY_MAX_ATTEMPTS=5
KITTY_DELIVERY_RETRY_BASE_SECONDS=1

# Optional extension points
KITTY_TOOL_MODULES=examples.tools
KITTY_HOOK_PATHS=

# Optional: enables POST /v1/messages in production
# KITTY_DEBUG_API_TOKEN=replace-with-a-separate-long-random-token
