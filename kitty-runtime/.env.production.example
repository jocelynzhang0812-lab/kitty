# Runtime mode
KITTY_ENV=production
KITTY_AGENT_MODE=csbot
KITTY_MODEL_PROVIDER=openai_compatible
KITTY_STATE_DIR=/data/kitty
KITTY_PROJECT_ROOT=/app
CS_DB_PATH=/data/kitty/cs_agent.db

# Optional: enables the internal POST /v1/messages endpoint in production
# KITTY_DEBUG_API_TOKEN=replace-with-a-separate-long-random-token

# OpenAI-compatible model API (Kimi defaults shown)
LLM_API_KEY=replace-me
LLM_BASE_URL=https://api.moonshot.cn/v1
LLM_MODEL=kimi-latest

# Feishu self-built app
FEISHU_APP_ID=cli_replace_me
FEISHU_APP_SECRET=replace-me
FEISHU_VERIFICATION_TOKEN=replace-me
FEISHU_ENCRYPT_KEY=replace-me
FEISHU_REQUIRE_MENTION=1
FEISHU_MAX_CLOCK_SKEW_SECONDS=300

# Feishu Bitable used by CS-bot feedback collection
BITABLE_APP_TOKEN=replace-me
BITABLE_TABLE_ID=replace-me
INTERNAL_DEBUG_CHAT_ID=oc_replace_me
FEEDBACK_BOT_USER_ID=ou_replace_me

# Optional separate product-feedback table
PRODUCT_FEEDBACK_APP_TOKEN=
PRODUCT_FEEDBACK_TABLE_ID=

# Optional internal notification mappings, encoded as JSON
FEISHU_CHAT_ID_MAP={}
FEISHU_USER_ID_MAP={}
